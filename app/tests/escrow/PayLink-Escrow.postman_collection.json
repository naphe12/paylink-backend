    {
      "name": "Webhook USDC - Invalid Signature",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Paylink-Signature",
            "value": "invalid-signature"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"network\": \"POLYGON\",\n  \"tx_hash\": \"{{tx_hash}}\",\n  \"log_index\": 0,\n  \"from_address\": \"{{from_address}}\",\n  \"to_address\": \"{{deposit_address}}\",\n  \"amount\": \"{{amount_usdc}}\",\n  \"confirmations\": 3\n}"
        },
        "url": "{{base_url}}/escrow/webhooks/usdc"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function randomHex(n) {",
              "  const chars = '0123456789abcdef';",
              "  let out = '';",
              "  for (let i = 0; i < n; i++) out += chars[Math.floor(Math.random() * chars.length)];",
              "  return out;",
              "}",
              "pm.collectionVariables.set('tx_hash', '0x' + randomHex(64));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 401 expected', function () { pm.expect(pm.response.code).to.eql(401); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Webhook USDC - Valid Signature",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Paylink-Signature",
            "value": "{{webhook_signature}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"network\": \"POLYGON\",\n  \"tx_hash\": \"{{tx_hash}}\",\n  \"log_index\": 1,\n  \"from_address\": \"{{from_address}}\",\n  \"to_address\": \"{{deposit_address}}\",\n  \"amount\": \"{{amount_usdc}}\",\n  \"confirmations\": 3\n}"
        },
        "url": "{{base_url}}/escrow/webhooks/usdc"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const raw = pm.variables.replaceIn(pm.request.body.raw || '');",
              "const secret = pm.collectionVariables.get('webhook_secret') || '';",
              "if (!secret) {",
              "  console.warn('webhook_secret is empty');",
              "}",
              "const sig = CryptoJS.HmacSHA256(raw, secret).toString(CryptoJS.enc.Hex);",
              "pm.collectionVariables.set('webhook_signature', sig);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('status returned', function () {",
              "  pm.expect(['OK', 'DUPLICATE', 'QUEUED_RETRY']).to.include(json.status);",
              "});"
            ]
          }
        }
      ]
    }
  ],
