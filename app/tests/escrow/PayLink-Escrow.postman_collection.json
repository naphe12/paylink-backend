{
  "info": {
    "_postman_id": "3a89a566-f8c9-4a3d-8d11-4db956cf5d6e",
    "name": "PayLink Escrow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection de test du module escrow (auth, ordre, sandbox, webhook)."
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "{{username}}",
              "type": "text"
            },
            {
              "key": "password",
              "value": "{{password}}",
              "type": "text"
            }
          ]
        },
        "url": "{{base_url}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.access_token || '');",
              "pm.test('access_token present', function () { pm.expect(json.access_token).to.be.a('string').and.not.empty; });"
            ]
          }
        }
      ]
    },
    {
      "name": "Escrow - Create Sandbox Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-SANDBOX",
            "value": "true"
          },
          {
            "key": "X-SANDBOX-SCENARIO",
            "value": "{{sandbox_scenario}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount_usdc\": {{amount_usdc}},\n  \"recipient_name\": \"Test Beneficiaire\",\n  \"recipient_phone\": \"+25770000001\",\n  \"deposit_network\": \"POLYGON\",\n  \"deposit_required_confirmations\": 1\n}"
        },
        "url": "{{base_url}}/escrow/orders"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('order_id', json.id || '');",
              "pm.test('order id present', function () { pm.expect(json.id).to.be.a('string').and.not.empty; });"
            ]
          }
        }
      ]
    },
    {
      "name": "Escrow - Get Order",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/escrow/orders/{{order_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('deposit_address', json.deposit_address || '');",
              "pm.test('deposit_address present', function () { pm.expect(json.deposit_address).to.be.a('string').and.not.empty; });"
            ]
          }
        }
      ]
    },
